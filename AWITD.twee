:: StoryScript [script]
window.story.state = { // Object storing global variables
  // CONSTANTS
  events: [ // Array of events that can occur
    /*{
      passageLink: "Something->TestEvent",
      html: 'Test event occurs!'
    }*/
    {
      passageLink: "Investigate->MatchEvent",
      html: "You see something lying on the path."
    },
    {
      passageLink: "Investigate->CampfireEvent",
      html: "You see something off in the distance."
    },
    {
      passageLink: "Investigate->WendigoEvent",
      html: "You see something off in the distance."
    },
    {
      passageLink: "Investigate->BrambleEvent",
      html: "You notice something a bit off the path."
    }
  ],
  eventFreq: {min: 5, max: 7}, // Min and max steps between events
  dist: 40, // Length of game in steps
  
  // VARIABLES
  step: 0,
  run: [], // Array contains all events that will occur in this session
  health: 2,
  matches: 0 // Number of matches held by player
};

function init() { // Function runs when Intro1 is shown, typically after Title.
  console.log("Init game");
  window.story.state.step = 0;
  window.story.state.run = [];
  window.story.state.health = 2;
  window.story.state.matches = 0;
  
  // Place events
  window.story.state.run = genEvents();
};

function genEvents() { // Return events list based on params.
  let length = window.story.state.dist;
  let min = window.story.state.eventFreq.min;
  let max = window.story.state.eventFreq.max;
  
  let i = 0;
  let events = new Array(length);
  
  while (i < length) {
    if (i != 0) {
      events[i] = window.story.state.events[randInt(0, window.story.state.events.length - 1)];
    }
    
    i += randInt(min, max);
  }
  
  events[length - 1] = {
  	passageLink: "Walk closer->Ending1",
    html: "You see something off in the distance."
  }
  
  console.log(events);
  
  return events;
}

function randInt(min, max) { // Returns random integer between min (inclusive) and max (inclusive)
	return Math.floor(Math.random() * (max - min + 1)) + min
}

function stepup() { // Function runs when passage StepUp is shown. Returns HTML to be shown after generic step up text.
  window.story.state.step += 1 // Increment step
  
  console.log(window.story.state.run[window.story.state.step]);
  
  let event = window.story.state.run[window.story.state.step]
  
  if (event != null) {
  	// Return event-specific HTML
    return event.html + '<div class="options">[[' + event.passageLink + ']]</div>';
  }
  
  return '<div class="options">[[Take another step->StepUp]]</div>'; // Default HTML to keep walking
};

function returnIfMatches(html) {
  if (window.story.state.matches == 0) {
    return "";
  };
  
  return html;
};

function damage(x) { // Inflicts damage to player. Also handles GameOver initiation.
  window.story.state.health -= x
  /*if (window.story.state.health == 0) {
    console.log("Moving to GameOver");
    window.story.show("GameOver");
  };*/
};

function dyingDead(a, b) { // Returns b if health = 0, otherwise a
  if (window.story.state.health == 0)
    return b;
  return a;
}

function chance(a, b, x) { // Returns a 1 out of x times
  if (randInt(1, x) == 1)
    return a;
  else
    return b;
}

:: StoryStylesheet [stylesheet]
body {
  font-family: "Courier New", monospace;
  background-color: black;
  color: white;
  left: 5%;
  top: 5%;
  position: fixed;
}

tw-passage {
  width: 90vw
}

div.options {
  bottom: 5%;
  position: fixed;
}

a {
  color: lightblue;
  text-decoration-color: lightblue;
  text-shadow: 0 0 8px #0099ff;
}

a:hover {
  color: #406cff;
  text-decoration-color: #406cff;
  text-shadow: 0 0 16px #0099ff;
}